@model ToDo_Manager.DTOs.RegisterUserDto
@{
    ViewData["Title"] = "Register";
}

<div class="auth-container">
    <div class="auth-card">
        <h2 class="auth-heading">Create account</h2>
        <p class="auth-subtitle">Sign up to start managing your tasks</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-error">
                @Html.ValidationSummary(true, "", new { @class = "" })
            </div>
        }

        <form asp-controller="Home" asp-action="Register" method="post" class="auth-form">
            <div class="form-group">
                <label asp-for="UserName" class="form-label">Username</label>
                <input asp-for="UserName" class="form-input" placeholder="Choose a username" />
                <span asp-validation-for="UserName" class="field-validation-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="form-label">Password</label>
                <input asp-for="Password" class="form-input" type="password" placeholder="Create a password" />
                <span asp-validation-for="Password" class="field-validation-error"></span>
            </div>

            <button type="submit" class="btn btn-auth-submit">Create Account</button>
        </form>

        <p class="auth-footer">
            Already have an account? <a asp-controller="Home" asp-action="Login">Sign in</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
